{
  "$schema": "https://www.krakend.io/schema/v3.json",
  "version": 3,
  "name": "grupo-cordillera-api-gateway",
  "port": 8088,
  "timeout": "10s",
  "cache_ttl": "0s",
  "extra_config": {
    "security/cors": {
      "allow_origins": ["*"],
      "allow_methods": ["GET", "POST", "OPTIONS"],
      "allow_headers": ["Content-Type", "Authorization"],
      "allow_credentials": false,
      "max_age": "12h"
    }
  },
  "endpoints": [
    {
      "endpoint": "/health",
      "method": "GET",
      "backend": [
        {
          "host": ["http://bff-service:8000"],
          "url_pattern": "/health",
          "method": "GET"
        }
      ],
      "input_headers": ["Content-Type", "Authorization"],
      "input_query_strings": ["*"],
      "output_encoding": "no-op"
    },
    {
      "endpoint": "/api/auth/login",
      "method": "POST",
      "backend": [
        {
          "host": ["http://bff-service:8000"],
          "url_pattern": "/api/auth/login",
          "method": "POST"
        }
      ],
      "input_headers": ["Content-Type", "Authorization"],
      "input_query_strings": ["*"],
      "output_encoding": "no-op"
    },
    {
      "endpoint": "/api/users",
      "method": "POST",
      "backend": [
        {
          "host": ["http://bff-service:8000"],
          "url_pattern": "/api/users",
          "method": "POST"
        }
      ],
      "input_headers": ["Content-Type", "Authorization"],
      "input_query_strings": ["*"],
      "output_encoding": "no-op"
    },
    {
      "endpoint": "/api/kpis/summary",
      "method": "GET",
      "backend": [
        {
          "host": ["http://bff-service:8000"],
          "url_pattern": "/api/kpis/summary",
          "method": "GET"
        }
      ],
      "input_headers": ["Content-Type", "Authorization"],
      "input_query_strings": ["*"],
      "output_encoding": "no-op"
    },
    {
      "endpoint": "/api/kpis/sales/monthly",
      "method": "GET",
      "backend": [
        {
          "host": ["http://bff-service:8000"],
          "url_pattern": "/api/kpis/sales/monthly",
          "method": "GET"
        }
      ],
      "input_headers": ["Content-Type", "Authorization"],
      "input_query_strings": ["*"],
      "output_encoding": "no-op"
    },
    {
      "endpoint": "/api/kpis/branches/performance",
      "method": "GET",
      "backend": [
        {
          "host": ["http://bff-service:8000"],
          "url_pattern": "/api/kpis/branches/performance",
          "method": "GET"
        }
      ],
      "input_headers": ["Content-Type", "Authorization"],
