      "output_encoding": "no-op"
    },
    {
      "endpoint": "/api/kpis/channels",
      "method": "GET",
      "backend": [
        {
          "host": ["http://bff-service:8000"],
          "url_pattern": "/api/kpis/channels",
          "method": "GET"
        }
      ],
      "input_headers": ["Content-Type", "Authorization"],
      "input_query_strings": ["*"],
      "output_encoding": "no-op"
    },
    {
      "endpoint": "/api/kpis/alerts",
      "method": "GET",
      "backend": [
        {
          "host": ["http://bff-service:8000"],
          "url_pattern": "/api/kpis/alerts",
          "method": "GET"
        }
      ],
      "input_headers": ["Content-Type", "Authorization"],
